# Prefer Homebrew on Apple Silicon but keep legacy /usr/local available.
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:$PATH"

if test -d "$HOME/.bun/bin"; then
  export PATH="$HOME/.bun/bin:$PATH"
fi

# GPG Key TTY
export GPG_TTY=$(tty)

function todo {
  touch ~/.todo
  local todo
  todo="$*"
  echo "$todo" >> ~/.todo
  cat -n ~/.todo
}

# GOPATH
if command -v go > /dev/null; then
  mkdir -p "$HOME/workspace/go/bin"
  export GOPATH="$HOME/workspace/go"
  export PATH="${GOPATH}/bin:$PATH"
fi

if command -v brew > /dev/null; then
  export HOMEBREW_PREFIX="$(brew --prefix)"
fi

if [[ "$OSTYPE" == darwin* ]]; then
  androidDefaultSdk="$HOME/Library/Android/sdk"
  androidLegacySdk="$HOME/Android/Sdk"
  androidHomebrewTools=""

  if test -n "$HOMEBREW_PREFIX" && test -d "$HOMEBREW_PREFIX/share/android-commandlinetools"; then
    androidHomebrewTools="$HOMEBREW_PREFIX/share/android-commandlinetools"
  fi

  if test -n "$androidHomebrewTools"; then
    if [[ "$ANDROID_HOME" == "$androidHomebrewTools" ]]; then
      unset ANDROID_HOME
    fi

    if [[ "$ANDROID_SDK_ROOT" == "$androidHomebrewTools" ]]; then
      unset ANDROID_SDK_ROOT
    fi
  fi

  if test -n "$ANDROID_HOME"; then
    export ANDROID_SDK_ROOT="${ANDROID_SDK_ROOT:-$ANDROID_HOME}"
  elif test -n "$ANDROID_SDK_ROOT"; then
    export ANDROID_HOME="$ANDROID_SDK_ROOT"
  elif test -d "$androidDefaultSdk" || test -n "$androidHomebrewTools"; then
    export ANDROID_SDK_ROOT="$androidDefaultSdk"
    export ANDROID_HOME="$ANDROID_SDK_ROOT"
  elif test -d "$androidLegacySdk"; then
    export ANDROID_SDK_ROOT="$androidLegacySdk"
    export ANDROID_HOME="$ANDROID_SDK_ROOT"
  fi

  function add_android_path {
    if test -d "$1"; then
      case ":$PATH:" in
        *":$1:"*) ;;
        *) export PATH="$1:$PATH" ;;
      esac
    fi
  }

  add_android_path "$androidHomebrewTools/cmdline-tools/latest/bin"

  if test -n "$ANDROID_SDK_ROOT"; then
    export ANDROID_HOME="${ANDROID_HOME:-$ANDROID_SDK_ROOT}"
    for dir in platform-tools emulator cmdline-tools/latest/bin cmdline-tools/bin; do
      if test -d "$ANDROID_SDK_ROOT/$dir"; then
        add_android_path "$ANDROID_SDK_ROOT/$dir"
      fi
    done
  fi

  unset -f add_android_path
  unset androidDefaultSdk androidLegacySdk androidHomebrewTools
fi

if test -f "/usr/bin/python"; then
  export CLOUDSDK_PYTHON="/usr/bin/python"
fi

if test -n "$HOMEBREW_PREFIX"; then
  gcloudSdkPath="${HOMEBREW_PREFIX}/Caskroom/google-cloud-sdk/latest/google-cloud-sdk"
  if test -d "${gcloudSdkPath}"; then
    for file in path completion; do
      [ -f "${gcloudSdkPath}/${file}.zsh.inc" ] &&
        source "${gcloudSdkPath}/${file}.zsh.inc"
    done
    export USE_GKE_GCLOUD_AUTH_PLUGIN=True
  fi
fi

if test -d "$HOME/google-cloud-sdk"; then
  gcloudSdkPath="$HOME/google-cloud-sdk"
  for file in path completion; do
    [ -f "${gcloudSdkPath}/${file}.zsh.inc" ] &&
      source "${gcloudSdkPath}/${file}.zsh.inc"
  done
fi

if command -v docker-machine > /dev/null; then
  if docker-machine active > /dev/null 2>&1; then
    eval "$(docker-machine env "$(docker-machine active)")"
  fi
fi

if command -v tk > /dev/null; then
  tk complete 2> /dev/null
fi

if command -v kubectl > /dev/null; then
  source <(kubectl completion zsh)
fi

if command -v helm > /dev/null; then
  source <(helm completion zsh)
fi

if command -v brew > /dev/null; then
  FPATH="$(brew --prefix)/share/zsh/site-functions:${FPATH}"

  autoload -Uz compinit
  compinit
fi

stty icrnl

if command -v ngrok > /dev/null; then
  eval "$(ngrok completion)"
fi

if command -v nvim > /dev/null; then
  alias vim=nvim
  export EDITOR=nvim
  export VISUAL=nvim
else
  export EDITOR=vim
fi

if command -v zoxide > /dev/null; then
  eval "$(zoxide init zsh --cmd cd)"
fi

function tat() {
  local session_name=$(basename "$PWD")
  local window_name=$session_name

  # Check if we're already inside a tmux session
  if [[ -n "$TMUX" ]]; then
    # We're inside tmux, just rename current window and set up panes
    local current_session=$(tmux display-message -p '#S')

    # Handle window naming conflicts within current session
    local counter=1
    local temp_name=$window_name
    while tmux list-windows -t "$current_session" -F '#W' 2>/dev/null | grep -qx "$temp_name"; do
      # Check if it's the current window
      if [[ $(tmux display-message -p '#W') == "$temp_name" ]]; then
        # It's the current window, we can just use this name
        break
      fi
      temp_name="${window_name}-${counter}"
      ((counter++))
    done
    window_name=$temp_name

    # Rename current window
    tmux rename-window "$window_name"

    # Set up the panes in current window
    tmux send-keys "nvim" C-m \; \
      split-window -v -p 30 \; \
      split-window -h \; \
      select-pane -t 0
  else
    # We're outside tmux, use the original behavior
    if tmux has-session -t "$session_name" 2>/dev/null; then
      tmux attach-session -t "$session_name"
    else
      tmux new-session -s "$session_name" -n "$window_name" -d \; \
        send-keys "nvim" C-m \; \
        split-window -v -p 30 \; \
        split-window -h \; \
        select-pane -t 2 \; \
        attach-session -t "$session_name"
    fi
  fi
}

if command -v mise > /dev/null; then
  eval "$(mise activate zsh)"
fi
